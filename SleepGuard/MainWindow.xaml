<Window x:Class="SleepGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SleepGuard"
        Icon="Resources/icon.ico"
        Width="800" Height="720"
        MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="#0E0D15"
        Foreground="#FFFFFF"
        FontFamily="Segoe UI"
        FontSize="13"
        Closing="Window_Closing">

    <Window.Resources>
        <!--
            背景:    #0E0D15 (ほぼ黒)
            カード:  #1B1929
            本文:    #FFFFFF / #E8E4F0
            副文:    #C4BFD8  ← 紫ではなく明るいグレー
            薄文:    #9893AE  ← 見出しラベル用
            アクセント: #7C73FF / #A78BFA
        -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Background" Value="#ECEAF4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>

                            <!-- 上ボタン -->
                            <RepeatButton Grid.Row="0"
                                          Command="ScrollBar.LineUpCommand"
                                          Interval="50" Delay="300">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="Bd" Background="#ECEAF4" CornerRadius="3,3,0,0">
                                            <Path Data="M 0,6 L 6,0 L 12,6"
                                                  Width="12" Height="7"
                                                  Stretch="Fill"
                                                  Stroke="#5A5870" StrokeThickness="1.5"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="Transparent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#D8D4F0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#C8C4E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>

                            <!-- トラック -->
                            <Border Grid.Row="1" Background="#ECEAF4"/>
                            <Track Grid.Row="1" x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#5A5870" CornerRadius="3" Margin="2,1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>

                            <!-- 下ボタン -->
                            <RepeatButton Grid.Row="2"
                                          Command="ScrollBar.LineDownCommand"
                                          Interval="50" Delay="300">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="Bd" Background="#ECEAF4" CornerRadius="0,0,3,3">
                                            <Path Data="M 0,0 L 6,6 L 12,0"
                                                  Width="12" Height="7"
                                                  Stretch="Fill"
                                                  Stroke="#5A5870" StrokeThickness="1.5"
                                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Fill="Transparent"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#D8D4F0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#C8C4E0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"      Value="#1B1929"/>
            <Setter Property="BorderBrush"     Value="#3AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20"/>
            <Setter Property="Margin"          Value="0,0,0,14"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#7C73FF"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,9"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.82"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.65"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#28243C"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C73FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Opacity" Value="0.7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddFromListBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#22D3A5"/>
            <Setter Property="BorderBrush"     Value="#4422D3A5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1522D3A5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTb" TargetType="TextBox">
            <Setter Property="Background"      Value="#0A0914"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderBrush"     Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="CaretBrush"      Value="#7C73FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="#7C73FF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Focusable="False" Height="4">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="#7C73FF" CornerRadius="2"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Focusable="False" Height="4">
                                    <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="#2C2840" CornerRadius="2"/></ControlTemplate></RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="16" Height="16">
                                    <Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Fill="#7C73FF"/></ControlTemplate></Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkChk" TargetType="CheckBox">
            <Setter Property="Foreground"  Value="#FFFFFF"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="ChkBd" Width="17" Height="17" CornerRadius="4"
                                    BorderBrush="#55FFFFFF" BorderThickness="1"
                                    Background="Transparent" Margin="0,0,7,0">
                                <Path x:Name="Mark" Data="M3,8 L7,12 L14,4"
                                      Stroke="#7C73FF" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChkBd" Property="Background"  Value="#207C73FF"/>
                                <Setter TargetName="ChkBd" Property="BorderBrush" Value="#7C73FF"/>
                                <Setter TargetName="Mark"  Property="Visibility"  Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanLB" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style x:Key="CleanLBI" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin"  Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer x:Name="RootScroll"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#0E0D15"
                  PreviewMouseWheel="RootScroll_PreviewMouseWheel">
        <StackPanel Margin="24,20,24,32">

            <!-- HEADER -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="9" Background="#7C73FF">
                        <TextBlock Text="S" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="SleepGuard" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="PROCESS SLEEP MONITOR" Foreground="#ADADC8" FontSize="9" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
                <Border x:Name="StatusBadge" Grid.Column="2" CornerRadius="14"
                        Padding="12,5" VerticalAlignment="Center"
                        Background="#22FFFFFF" BorderBrush="#44FFFFFF" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="#ADADC8" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" Text="待機中" Foreground="#FFFFFF"
                                   FontFamily="Consolas" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- COUNTDOWN -->
            <Border x:Name="CountdownBanner" CornerRadius="8" Padding="14,9" Margin="0,0,0,14"
                    Visibility="Collapsed" Background="#1AF59E0B" BorderBrush="#60F59E0B" BorderThickness="1">
                <TextBlock x:Name="CountdownText" Foreground="#F59E0B" FontFamily="Consolas" FontSize="11"/>
            </Border>

            <!-- STAT CARDS -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- STATUS -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="STATUS" Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,0,0,6"/>
                        <TextBlock x:Name="StatStatusText" Text="待機中" FontSize="22" FontWeight="Bold" Foreground="#ADADC8"/>
                        <TextBlock x:Name="StatStatusSub"  Text="監視中" Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <!-- RUNNING COUNT -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="実行中プロセス" Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,0,0,6"/>
                        <TextBlock x:Name="StatRunningCount" Text="0" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
                        <TextBlock x:Name="StatWatchedCount" Text="/ 0 登録" Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <!-- DELAY -->
                <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="スリープ猶予" Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,0,0,6"/>
                        <TextBlock x:Name="StatDelay" Text="5 分" FontSize="22" FontWeight="Bold" Foreground="#A78BFA"/>
                        <TextBlock Text="全プロセス停止後" Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- RUNNING CHIPS -->
            <WrapPanel x:Name="RunningChipsPanel" Margin="0,0,0,14"/>

            <!-- WATCHED PROCESS LIST -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="監視プロセス一覧" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ProcessCountLabel" Grid.Column="1"
                                   Foreground="#ADADC8" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                    <ScrollViewer x:Name="ProcessListScrollViewer"
                                  MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="ProcessListBox" Style="{StaticResource CleanLB}"
                                 ItemContainerStyle="{StaticResource CleanLBI}"/>
                    </ScrollViewer>
                    <Border x:Name="EmptyState" Padding="20,22" CornerRadius="8" Margin="0,4,0,0"
                            Visibility="Collapsed" Background="#0CFFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
                        <TextBlock Text="監視対象プロセスが登録されていません&#x0a;下のフォームから追加してください"
                                   TextAlignment="Center" Foreground="#CCCCCC"
                                   FontFamily="Consolas" FontSize="11" LineHeight="20"/>
                    </Border>
                    <!-- Add form -->
                    <Border Margin="0,14,0,0" Padding="14" CornerRadius="8" Background="#100F1C">
                        <StackPanel>
                            <TextBlock Text="EXEファイルから追加" Foreground="#ADADC8"
                                       FontFamily="Consolas" FontSize="10" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ExePathBox" Grid.Column="0" Style="{StaticResource DarkTb}"
                                         Height="36" VerticalContentAlignment="Center"/>
                                <TextBox x:Name="DisplayNameBox" Grid.Column="2" Style="{StaticResource DarkTb}"
                                         Height="36" VerticalContentAlignment="Center"/>
                                <Button Grid.Column="4" Content="参照..." Style="{StaticResource GhostBtn}"
                                        Height="36" Click="BrowseButton_Click"/>
                                <Button Grid.Column="6" Content="追加" Style="{StaticResource PrimaryBtn}"
                                        Height="36" Padding="20,0" Click="AddProcessButton_Click"/>
                            </Grid>
                            <TextBlock x:Name="AddErrorText" Foreground="#F87171"
                                       FontFamily="Consolas" FontSize="10" Margin="0,6,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- RUNNING PROCESS PICKER -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="実行中プロセスから登録" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="現在起動中のアプリを直接選択して監視対象に追加"
                                       Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="↻ 更新" Style="{StaticResource GhostBtn}"
                                Padding="10,5" Click="RefreshRunningProcesses_Click" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <TextBox x:Name="ProcessSearchBox" Style="{StaticResource DarkTb}"
                                 Height="34" VerticalContentAlignment="Center"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="プロセス名で絞り込み..."
                                   Foreground="#ADADC8" FontFamily="Consolas" FontSize="11"
                                   Margin="11,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center"/>
                    </Grid>
                    <Border Height="1" Background="#2AFFFFFF" Margin="0,0,0,8"/>
                    <ScrollViewer x:Name="RunningListScrollViewer"
                                  MaxHeight="190" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ListBox x:Name="RunningProcessListBox" Style="{StaticResource CleanLB}"
                                 ItemContainerStyle="{StaticResource CleanLBI}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- SETTINGS -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="設定" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <!-- Sleep delay -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="スリープ猶予時間" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="全プロセス停止後、この時間でスリープ許可"
                                       Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Slider x:Name="SleepDelaySlider" Grid.Column="1"
                                Minimum="1" Maximum="60" Value="5"
                                Style="{StaticResource DarkSlider}"
                                TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SleepDelayLabel" Grid.Column="2" Text="5 分"
                                   Foreground="#A78BFA" FontFamily="Consolas" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="#2AFFFFFF" Margin="0,0,0,14"/>

                    <!-- Check interval -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="確認間隔" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="プロセスをチェックする頻度"
                                       Foreground="#ADADC8" FontFamily="Consolas" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Slider x:Name="CheckIntervalSlider" Grid.Column="1"
                                Minimum="5" Maximum="60" Value="10"
                                Style="{StaticResource DarkSlider}"
                                TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CheckIntervalLabel" Grid.Column="2" Text="10 秒"
                                   Foreground="#A78BFA" FontFamily="Consolas" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="#2AFFFFFF" Margin="0,0,0,14"/>

                    <!-- Checkboxes -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="PreventDisplayChk" Grid.Row="0" Grid.Column="0"
                                  Content="ディスプレイのスリープも防止" Style="{StaticResource DarkChk}"/>
                        <CheckBox x:Name="StartMinimizedChk" Grid.Row="0" Grid.Column="1"
                                  Content="起動時にタスクトレイに格納" Style="{StaticResource DarkChk}"/>
                        <CheckBox x:Name="ResidentModeChk" Grid.Row="2" Grid.Column="0"
                                  Content="タスクトレイに常駐する" Style="{StaticResource DarkChk}" IsChecked="True"/>
                        <CheckBox x:Name="LogEnabledChk" Grid.Row="2" Grid.Column="1"
                                  Content="動作ログを記録する" Style="{StaticResource DarkChk}" IsChecked="True"/>
                        <CheckBox x:Name="StartupChk" Grid.Row="4" Grid.Column="0"
                                  Content="Windows起動時に自動起動" Style="{StaticResource DarkChk}"/>
                        <Button Grid.Row="4" Grid.Column="1"
                                Content="ログファイルを開く" Style="{StaticResource GhostBtn}"
                                HorizontalAlignment="Left" Padding="10,5" Click="OpenLogButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- LOG -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最近のログ" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold"/>
                        <Button Grid.Column="1" Content="クリア" Style="{StaticResource GhostBtn}"
                                Padding="10,4" Click="ClearLogButton_Click"/>
                    </Grid>
                    <Border Background="#0A0914" CornerRadius="7" Padding="12">
                        <ScrollViewer x:Name="LogScrollViewer" MaxHeight="110" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="LogPanel"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
